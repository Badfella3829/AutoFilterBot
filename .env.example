# ============================================
# AutoFilterBot Configuration
# Copy this file to .env and fill in values
# ============================================

# Required: Telegram API credentials (get from https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# Required: MongoDB connection string
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=Cluster0

# Optional: File Database (defaults to main database if not set)
# FILE_DB_URL=
# FILE_DB_NAME=

# Bot Admins (space-separated user IDs)
ADMINS=123456789 987654321

# Log Channel (channel ID where bot logs are sent)
LOG_CHANNEL=-1001234567890

# Channels to index (space-separated channel IDs or usernames)
CHANNELS=-1001234567890 @yourchannel

# Optional: Force subscription channel
# AUTH_CHANNEL=-1001234567890

# Optional: Authorized users (space-separated)
# AUTH_USERS=

# Optional: Authorized groups (space-separated)
# AUTH_GROUP=

# Feature toggles
WEBHOOK=True
PMFILTER=True
G_FILTER=True
BUTTON_LOCK=True
IMDB=True
PM_IMDB=True
SINGLE_BUTTON=True
SPELL_CHECK_REPLY=True
MELCOW_NEW_USERS=True
PROTECT_CONTENT=False
PUBLIC_FILE_STORE=True
P_TTI_SHOW_OFF=True
LONG_IMDB_DESCRIPTION=False

# UI Configuration
MAX_RIST_BTNS=10
IMDB_DELET_TIME=300
CACHE_TIME=300

# URL Shortener (optional)
# SHORT_URL=https://your-shortener.com
# SHORT_API=your_api_key

# Support Chat username (without @)
SUPPORT_CHAT=YourSupportChat

# Custom captions (optional)
# CUSTOM_FILE_CAPTION={file_name}
# BATCH_FILE_CAPTION=

# File Store Channel (for batch files)
# FILE_STORE_CHANNEL=-1001234567890

# RemoveBG API (optional, for image editing)
# RemoveBG_API=
