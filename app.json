{
    "name": "AutoFilterBot",
    "description": "A powerful Telegram auto-filter bot for indexing and searching media files",
    "logo": "https://te.legra.ph/file/94bc067909902a02eaf20.jpg",
    "keywords": ["Telegram", "auto-filter", "bot", "media", "search"],
    "repository": "https://github.com/DevilServers/AutoFilterbot",
    "stack": "container",
    "env": {
        "WEB_SUPPORT": {
            "description": "Enable web server for health checks (True/False)",
            "value": "True",
            "required": true
        },
        "BOT_TOKEN": {
            "description": "Telegram bot token from @BotFather",
            "required": true
        },
        "API_ID": {
            "description": "Telegram API ID from my.telegram.org",
            "required": true
        },
        "API_HASH": {
            "description": "Telegram API Hash from my.telegram.org",
            "required": true
        },
        "ADMINS": {
            "description": "Space-separated list of admin user IDs",
            "required": true
        },
        "DATABASE_URL": {
            "description": "MongoDB connection URI",
            "required": true
        },
        "DATABASE_NAME": {
            "description": "MongoDB database name",
            "value": "AutoFilterBot",
            "required": false
        },
        "LOG_CHANNEL": {
            "description": "Channel ID for logging (format: -100xxxxxxxxxx)",
            "required": true
        },
        "CHANNELS": {
            "description": "Source channels for indexing (space-separated IDs)",
            "required": false
        },
        "AUTH_CHANNEL": {
            "description": "Force subscribe channel ID",
            "required": false
        },
        "SUPPORT_CHAT": {
            "description": "Support group username (without @)",
            "value": "DevilServers",
            "required": false
        },
        "PICS": {
            "description": "Telegraph image URLs for start message (space-separated)",
            "value": "https://te.legra.ph/file/94bc067909902a02eaf20.jpg",
            "required": false
        },
        "COLLECTION_NAME": {
            "description": "MongoDB collection name for files",
            "value": "Telegram_files",
            "required": false
        },
        "MAX_RIST_BTNS": {
            "description": "Maximum search result buttons (max 10)",
            "value": "10",
            "required": false
        },
        "CUSTOM_FILE_CAPTION": {
            "description": "Custom file caption template",
            "value": "{file_name}\n\nSize: {file_size}",
            "required": false
        },
        "IMDB": {
            "description": "Enable IMDB integration (True/False)",
            "value": "True",
            "required": false
        },
        "PM_IMDB": {
            "description": "Enable IMDB in PM (True/False)",
            "value": "True",
            "required": false
        },
        "IMDB_TEMPLATE": {
            "description": "Custom IMDB template",
            "value": "<b>Query: {query}</b>\n\nTitle: <a href={url}>{title}</a>\nGenres: {genres}\nYear: {year}\nRating: {rating}/10",
            "required": false
        },
        "IMDB_DELET_TIME": {
            "description": "Auto-delete time for IMDB results (seconds)",
            "value": "300",
            "required": false
        },
        "SINGLE_BUTTON": {
            "description": "Use single button layout (True/False)",
            "value": "True",
            "required": false
        },
        "PROTECT_CONTENT": {
            "description": "Restrict content forwarding (True/False)",
            "value": "False",
            "required": false
        },
        "PMFILTER": {
            "description": "Enable PM auto-filter (True/False)",
            "value": "True",
            "required": false
        },
        "G_FILTER": {
            "description": "Enable global filter (True/False)",
            "value": "True",
            "required": false
        },
        "BUTTON_LOCK": {
            "description": "Lock buttons to requester (True/False)",
            "value": "True",
            "required": false
        },
        "P_TTI_SHOW_OFF": {
            "description": "Result buttons as URL or callback (True=URL, False=callback)",
            "value": "True",
            "required": false
        },
        "SHORT_URL": {
            "description": "URL shortener domain",
            "required": false
        },
        "SHORT_API": {
            "description": "URL shortener API key",
            "required": false
        }
    },
    "formation": {
        "web": {
            "quantity": 1,
            "size": "eco"
        }
    },
    "buildpacks": [
        {
            "url": "heroku/python"
        }
    ]
}
